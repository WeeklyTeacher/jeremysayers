---
// /home/r_/projects/jeremysayers/src/pages/education.astro
import PageIntro from '../components/PageIntro.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { educationPillars } from '../data/site';
---

<SiteLayout
  title="Education | Jeremy Sayers"
  description="Jeremy Sayers on teaching experience, student opportunity, STEM, robotics, innovation, and leadership in education."
>
  <PageIntro
    title="Education"
    description="Jeremy’s work in education combines classroom depth, leadership experience, innovation-minded thinking, and a practical belief that opportunity should feel real for students."
  />

  <section>
    <div class="shell education-grid">
      <div class="stack">
        <SectionHeading
          eyebrow="Teaching and Leadership"
          title="Grounded in classrooms, expanded through broader educational leadership."
          text="Jeremy’s perspective is shaped by direct teaching, Magnet Coordinator leadership, and an interest in better systems for students and families."
        />
        <p>
          Teaching every elementary grade from kindergarten through fifth creates a clearer view of how students learn,
          where they struggle, and what stronger support actually looks like. That kind of continuity matters because
          it keeps educational decisions anchored in real developmental experience.
        </p>
        <p>
          Jeremy’s work also reflects ongoing interest in STEM, robotics, innovation, and applied learning. The aim is
          not to chase trends, but to create experiences that help students become more capable, more curious, and more
          confident as thinkers and builders.
        </p>
      </div>
      <aside class="panel panel--navy">
        <p class="eyebrow">Education Philosophy</p>
        <h3>Good schools widen the horizon for students and families.</h3>
        <p>
          Strong instruction, clear systems, high expectations, and meaningful access to opportunity are not extras.
          They are the foundation.
        </p>
      </aside>
    </div>
  </section>

  <section>
    <div class="shell">
      <SectionHeading
        eyebrow="Focus Areas"
        title="A practical education agenda without slogans."
      />
      <div class="signal-grid">
        {educationPillars.map((item) => (
          <article class="signal-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</SiteLayout>
