---
// /home/r_/projects/jeremysayers/src/pages/about.astro
import PageIntro from '../components/PageIntro.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { site } from '../data/site';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Jeremy Sayers',
  url: `${site.url}/about/`,
  description:
    'Background on Jeremy Sayers, including his classroom experience, leadership work, recognition, projects, and civic interest.'
};
---

<SiteLayout
  title="About Jeremy Sayers | Educator, Builder, and Community-Minded Leader"
  description="Learn about Jeremy Sayers’s background in teaching, school leadership, practical project building, and community-minded work in Torrance, California."
  structuredData={structuredData}
>
  <PageIntro
    title="About Jeremy Sayers"
    description="I’m an award-winning educator, builder, and Torrance resident whose work has been shaped by classrooms, practical problem-solving, and a real interest in community life."
  />

  <section class="section-band section-band--paper">
    <div class="shell about-grid">
      <div class="stack about-intro">
        <SectionHeading
          eyebrow="Introduction"
          title="My work has grown out of classrooms, school leadership, and building useful things."
        />
        <p>
          I’ve spent years teaching, building programs, and creating practical projects. In 2023, I was honored to be
          named LAUSD Teacher of the Year, and that recognition meant a lot because it came from the real work of
          serving students and families well.
        </p>
        <p>
          I’ve taught every elementary grade from kindergarten through fifth, and that gives me a broad view of how
          children grow, where families need support, and how much clear systems and strong relationships matter over
          time. This site is where I share that work, the ideas behind it, and the projects I’m building.
        </p>
      </div>

      <aside class="stack">
        <article class="pullquote-card">
          <h3>Guiding idea</h3>
          <p>
            I believe good schools expand possibility. The work is not just about one classroom on one day. It is about
            building stronger opportunities and better outcomes over time.
          </p>
        </article>
        <article class="panel">
          <p class="eyebrow">Recognition</p>
          <h3>LAUSD Teacher of the Year, 2023</h3>
          <p>
            My work has been recognized for classroom excellence and for the broader leadership, communication, and
            follow-through that strong schools require.
          </p>
        </article>
      </aside>
    </div>
  </section>

  <section class="section-band section-band--warm">
    <div class="shell">
      <SectionHeading
        eyebrow="How I Got Here"
        title="Teaching across K-5 shaped how I think about students, families, and schools."
      />
      <div class="about-story-grid">
        <article class="panel">
          <h3>Classroom experience</h3>
          <p>
            Teaching every elementary grade gave me a practical view of learning, development, and the transitions that
            matter most. It also taught me that strong schools depend on trust, consistency, and communication with
            families.
          </p>
        </article>
        <article class="panel">
          <h3>What that taught me</h3>
          <p>
            The classroom keeps your perspective honest. It shows what actually helps students, what creates friction,
            and how important it is for opportunity to feel real, not theoretical.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-band section-band--paper">
    <div class="shell">
      <SectionHeading
        eyebrow="Leadership and Program Building"
        title="Serving as Magnet Coordinator widened my lens from one classroom to the whole school community."
      />
      <p class="about-section-lead">
        As Magnet Coordinator, I spent more time thinking about program identity, family communication, student
        recruitment, and the systems that help a school feel strong and coherent. That work deepened my interest in
        how schools connect with the community around them.
      </p>
    </div>
  </section>

  <section class="section-band section-band--slate">
    <div class="shell">
      <SectionHeading
        eyebrow="Builder Mentality"
        title="I also like building practical sites and projects that solve real problems."
      />
      <p class="about-section-lead">
        I’ve created projects including EdThings.com, NoMoreBills.com, and MathAndEnglishWorksheets.com because I enjoy
        turning ideas into tools people can actually use. That builder mentality is a big part of how I approach both
        education and problem-solving more broadly.
      </p>
    </div>
  </section>

  <section class="section-band section-band--accent">
    <div class="shell">
      <SectionHeading
        eyebrow="What I Care About"
        title="The through-line is applied learning, stronger schools, and constructive community life."
      />
      <p class="about-section-lead">
        I care about STEM, robotics, hands-on learning, innovation that actually helps people, and stronger
        school-community partnership. I’m also shaped by a longstanding interest in history, local community life, and
        the kind of public service that is steady, thoughtful, and useful.
      </p>
    </div>
  </section>

  <section class="section-band section-band--paper">
    <div class="shell">
      <SectionHeading
        eyebrow="Why This Site Exists"
        title="This site gives me one place to share updates, ideas, and future work."
      />
      <p class="about-section-lead">
        It’s a place to share education ideas, practical projects, local observations, and community-minded work in a
        voice that feels honest to me. If you follow along, you can expect thoughtful updates rather than constant
        noise.
      </p>
    </div>
  </section>
</SiteLayout>
