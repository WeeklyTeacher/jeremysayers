---
// /home/r_/projects/jeremysayers/src/pages/about.astro
import PageIntro from '../components/PageIntro.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { aboutTimeline, site } from '../data/site';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Jeremy Sayers',
  url: `${site.url}/about/`,
  description:
    'Background on Jeremy Sayers, including his classroom experience, leadership work, recognition, projects, and civic interest.'
};
---

<SiteLayout
  title="About Jeremy Sayers | Educator, Builder, Writer, and Community-Minded Leader"
  description="Learn about Jeremy Sayers’s background in education, leadership, project building, and public-interest work in Torrance, California."
  structuredData={structuredData}
>
  <PageIntro
    title="About Jeremy"
    description="Jeremy Sayers brings together classroom experience, school leadership, practical project-building, and a long-term interest in constructive community life in Torrance."
  />

  <section>
    <div class="shell about-grid">
      <div class="stack">
        <SectionHeading
          eyebrow="Background"
          title="An educator-builder profile shaped by direct experience, not abstraction."
          text="This page is intentionally human and search-friendly at the same time: it explains Jeremy’s work clearly while giving readers a fuller sense of his values and direction."
        />
        <p>
          Jeremy is an award-winning educator whose professional life has been built in classrooms, school leadership,
          and practical efforts to expand student opportunity. He has taught every elementary grade from kindergarten
          through fifth, an experience that gives him perspective on academic growth, developmental readiness, and the
          systems that help students thrive over time.
        </p>
        <p>
          He also served as a Magnet Coordinator, where his work expanded beyond one classroom into broader questions of
          program quality, family communication, school identity, and access to strong educational opportunities. That
          leadership period helped sharpen a style rooted in collaboration, implementation, and useful follow-through.
        </p>
        <p>
          Jeremy’s work extends beyond school walls through websites and learning-focused projects that turn ideas into
          usable resources. He is interested in STEM, robotics, innovation, educational opportunity, and stronger
          pathways for students and families.
        </p>
        <p>
          Based in Torrance, California, he is also building a thoughtful public-facing platform for community-minded
          reflection, practical school ideas, and future public-interest work. The tone of that work is deliberate:
          credible, substantial, grounded, and not performative.
        </p>
      </div>

      <aside class="stack">
        <article class="pullquote-card">
          <h3>Guiding idea</h3>
          <p>
            Excellent education expands possibility. The goal is not only strong teaching in the moment, but better
            opportunities, stronger systems, and clearer pathways over time.
          </p>
        </article>
        <article class="panel">
          <p class="eyebrow">Recognition</p>
          <h3>Teacher of the Year</h3>
          <p>
            Jeremy was recognized as LAUSD Teacher of the Year in 2023, a distinction that reflects the substance of
            his classroom practice and broader educational impact.
          </p>
        </article>
      </aside>
    </div>
  </section>

  <section>
    <div class="shell">
      <SectionHeading
        eyebrow="Professional Arc"
        title="A path that moves from teaching to leadership to a broader civic and editorial voice."
      />
      <div class="timeline">
        {aboutTimeline.map((item) => (
          <article class="timeline-card">
            <span class="timeline-card__period">{item.period}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</SiteLayout>
