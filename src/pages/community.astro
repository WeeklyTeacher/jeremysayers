---
// /home/r_/projects/jeremysayers/src/pages/community.astro
import PageIntro from '../components/PageIntro.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { communityPrinciples } from '../data/site';
---

<SiteLayout
  title="Community | Jeremy Sayers"
  description="Jeremy Sayers on stronger schools, family engagement, practical leadership, and constructive local ideas in Torrance."
>
  <PageIntro
    title="Community"
    description="This page is about constructive community-minded leadership: stronger schools, family trust, practical local ideas, and a belief that listening should come before slogans."
  />

  <section>
    <div class="shell community-grid">
      <div class="stack">
        <SectionHeading
          eyebrow="Local Perspective"
          title="Community work should feel grounded, useful, and close to people’s real lives."
        />
        <p>
          Jeremy’s interest in civic life is not about rehearsing campaign promises. It is about paying attention to
          how schools, families, and neighborhoods actually experience local systems and asking what practical
          leadership would look like in response.
        </p>
        <p>
          That includes stronger family engagement, clearer communication, more confidence in local institutions, and a
          deeper commitment to opportunities that help young people grow into capable adults.
        </p>
      </div>

      <aside class="pullquote-card">
        <h3>Constructive tone matters.</h3>
        <p>
          The site deliberately avoids election-site language. The goal is credibility, reflection, and a useful public
          voice that can grow in scope later without sounding premature now.
        </p>
      </aside>
    </div>
  </section>

  <section>
    <div class="shell">
      <SectionHeading
        eyebrow="Principles"
        title="Community leadership starts with trust, clarity, and follow-through."
      />
      <div class="signal-grid">
        {communityPrinciples.map((item) => (
          <article class="signal-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</SiteLayout>
