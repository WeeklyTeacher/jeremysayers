---
// /home/r_/projects/jeremysayers/src/pages/newsletter/resend.astro
import PageIntro from '../../components/PageIntro.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

export const prerender = false;

const status = Astro.url.searchParams.get('status');
const email = Astro.url.searchParams.get('email')?.trim() || '';
---

<SiteLayout
  title="Resend Confirmation | Jeremy Sayers"
  description="Request a fresh newsletter confirmation email from Jeremy Sayers."
  showSitewideSignup={false}
  robots="noindex,nofollow"
>
  <PageIntro
    title="Resend Confirmation"
    description="Request a fresh confirmation email if your original subscription link expired or never arrived."
  />

  <section class="section-band section-band--paper">
    <div class="shell stay-grid">
      <div class="stack">
        <article class="panel">
          <h2>Need a new confirmation email?</h2>
          <p>
            Enter your email address below and, if there is a pending subscription that can be confirmed, a fresh link
            will be sent.
          </p>
          {
            status === 'sent' && (
              <p class="newsletter-form__status">
                If a pending subscription exists for that email, a fresh confirmation message is on the way.
              </p>
            )
          }
          {
            status === 'invalid-email' && (
              <p class="newsletter-form__status newsletter-form__status--error" role="alert">
                Please enter a valid email address.
              </p>
            )
          }
        </article>
      </div>

      <article class="signup-card">
        <form class="newsletter-form" action="/api/newsletter/resend" method="POST">
          <label>
            <span class="sr-only">Email Address</span>
            <input
              type="email"
              name="email"
              placeholder="Email Address"
              value={email}
              autocomplete="email"
              required
            />
          </label>
          <button type="submit">Send Confirmation Email</button>
        </form>
      </article>
    </div>
  </section>
</SiteLayout>
