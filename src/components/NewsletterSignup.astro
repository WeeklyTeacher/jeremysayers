---
// /home/r_/projects/jeremysayers/src/components/NewsletterSignup.astro
import { randomUUID } from 'node:crypto';

interface Props {
  title?: string;
  text?: string;
  sourceContext?: string;
  compact?: boolean;
  eyebrow?: string;
}

const {
  title = 'Let’s build better schools together',
  text = 'Get updates on education leadership, STEM, robotics, community partnership, and practical school innovation.',
  sourceContext = 'site',
  compact = false,
  eyebrow = 'Stay Connected'
} = Astro.props;

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const enableClientDebug = import.meta.env.DEV;
const status = Astro.url.searchParams.get('newsletter');
const formAction = new URL('/api/newsletter', Astro.url).pathname;
const formInstanceId = `newsletter-${randomUUID()}`;
const turnstileSuccessCallback = `onNewsletterTurnstileSuccess_${formInstanceId}`;
const turnstileExpiredCallback = `onNewsletterTurnstileExpired_${formInstanceId}`;

const newsletterMessages = {
  success: 'Thanks. You are on the list for future updates from Jeremy.',
  duplicate: 'That email is already subscribed for updates.',
  'missing-email': 'Please enter your email address.',
  'invalid-email': 'Please enter a valid email address.',
  'missing-first-name': 'Please enter your first name.',
  'missing-turnstile-site-key': 'Spam protection is not configured yet.',
  'missing-turnstile-secret': 'The newsletter service is not fully configured yet.',
  'turnstile-missing-field': 'Spam protection could not attach to the form.',
  'turnstile-missing-token': 'Please complete the spam protection check.',
  'turnstile-failed': 'Spam protection verification failed. Please try again.',
  'bad-method': 'This signup request used the wrong method.',
  'bad-request': 'The signup request could not be processed.',
  'db-error': 'The newsletter service is temporarily unavailable. Please try again.',
  'unknown-error': 'Something went wrong. Please try again.'
} as const;

type NewsletterState = keyof typeof newsletterMessages;

const isKnownStatus = status && status in newsletterMessages;
const isError =
  status &&
  status !== 'success' &&
  status !== 'duplicate' &&
  status in newsletterMessages;
---

<section class={`signup-card ${compact ? 'signup-card--compact' : ''}`}>
  <div class="signup-card__copy">
    <p class="eyebrow">{eyebrow}</p>
    <h3>{title}</h3>
    <p>{text}</p>
  </div>
  <form
    class={`newsletter-form ${compact ? 'newsletter-form--compact' : ''}`}
    action={formAction}
    method="POST"
    data-newsletter-form
    data-newsletter-form-id={formInstanceId}
    data-debug-submit={enableClientDebug ? 'true' : 'false'}
  >
    <div class="newsletter-form__row">
      <label>
        <span class="sr-only">First Name</span>
        <input type="text" name="firstName" placeholder="First Name" autocomplete="given-name" required />
      </label>
      <label>
        <span class="sr-only">Last Name</span>
        <input type="text" name="lastName" placeholder="Last Name" autocomplete="family-name" />
      </label>
    </div>
    <label>
      <span class="sr-only">Email Address</span>
      <input type="email" name="email" placeholder="Email Address" autocomplete="email" required />
    </label>
    <label>
      <span class="sr-only">Interests or Comments</span>
      <textarea name="interests" rows="4" placeholder="Interests or Comments"></textarea>
    </label>

    <input type="hidden" name="sourceContext" value={sourceContext} />
    <input type="hidden" name="sourcePage" value={Astro.url.pathname} />

    {
      turnstileSiteKey && (
        <div class="newsletter-form__turnstile">
          <!-- Local development on localhost should use Cloudflare Turnstile testing keys. -->
          <input type="hidden" name="cf-turnstile-response" value="" data-turnstile-response />
          <div
            class="cf-turnstile"
            data-sitekey={turnstileSiteKey}
            data-theme="light"
            data-appearance="always"
            data-size="flexible"
            data-callback={turnstileSuccessCallback}
            data-expired-callback={turnstileExpiredCallback}
            data-error-callback={turnstileExpiredCallback}
          ></div>
        </div>
      )
    }

    <button type="submit">Join the Community</button>
    {
      isKnownStatus && (
        <p class:list={['newsletter-form__status', isError && 'newsletter-form__status--error']} role={isError ? 'alert' : 'status'}>
          {newsletterMessages[status as NewsletterState]}
        </p>
      )
    }
  </form>
  <p class="fine-print">
    This updates form is intended for community-minded communication about schools, ideas, projects, and future work.
  </p>
</section>

{turnstileSiteKey && <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>}
<script is:inline define:vars={{ formInstanceId, turnstileSuccessCallback, turnstileExpiredCallback }}>
  (() => {
    const form = document.querySelector(`[data-newsletter-form-id="${formInstanceId}"]`);
    if (!(form instanceof HTMLFormElement)) return;

    const syncNewsletterTurnstileToken = (form, token = '') => {
      const tokenInput = form?.querySelector('[data-turnstile-response]');
      if (tokenInput instanceof HTMLInputElement) {
        tokenInput.value = token;
      }
    };

    window[turnstileSuccessCallback] = (token) => {
      console.log('[newsletter-form] turnstile success', {
        formInstanceId,
        tokenLength: typeof token === 'string' ? token.length : 0,
      });
      syncNewsletterTurnstileToken(form, token);
    };

    window[turnstileExpiredCallback] = () => {
      console.log('[newsletter-form] turnstile expired', { formInstanceId });
      syncNewsletterTurnstileToken(form, '');
    };

    if (form.dataset.turnstileBound === 'true') return;
    form.dataset.turnstileBound = 'true';

    form.addEventListener('submit', () => {
      const injectedTurnstileInput = form.querySelector(
        'input[name="cf-turnstile-response"]:not([data-turnstile-response])'
      );
      const hiddenTurnstileInput = form.querySelector('[data-turnstile-response]');

      console.log('[newsletter-form] submit token state', {
        formInstanceId,
        hiddenTokenLength:
          hiddenTurnstileInput instanceof HTMLInputElement ? hiddenTurnstileInput.value.length : 0,
        injectedTokenLength:
          injectedTurnstileInput instanceof HTMLInputElement ? injectedTurnstileInput.value.length : 0,
      });

      if (
        injectedTurnstileInput instanceof HTMLInputElement &&
        hiddenTurnstileInput instanceof HTMLInputElement &&
        !hiddenTurnstileInput.value
      ) {
        hiddenTurnstileInput.value = injectedTurnstileInput.value;
      }

      if (form.dataset.debugSubmit === 'true') {
        const formData = new FormData(form);
        console.log(
          '[newsletter-form] submit payload',
          Object.fromEntries(formData.entries())
        );
      }
    });
  })();
</script>
